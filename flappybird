<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Flappy Bird</title>
<script src="https://telegram.org/js/telegram-web-app.js"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@600;700;800&family=Nunito:wght@400;600;700&display=swap" rel="stylesheet">
<style>
  :root{--sky-top:#BFF3E0;--sky-bottom:#E9FBEF;--ink:#1E4635;--ink-soft:#4C7767;
    --green:#35C57A;--green-dark:#1E9E5E;--card-bg:#FFFFFF;--yellow:#FFC94D;}
  *{box-sizing:border-box;-webkit-tap-highlight-color:transparent;user-select:none;}
  html,body{margin:0;padding:0;height:100%;font-family:'Nunito',sans-serif;color:var(--ink);
    background:linear-gradient(180deg,var(--sky-top) 0%,var(--sky-bottom) 55%,#FFF7E0 100%);overflow:hidden;}
  .wrap{max-width:480px;margin:0 auto;padding:14px 14px 10px;display:flex;flex-direction:column;height:100vh;}
  .plumbob{width:30px;height:30px;margin:0 auto 4px;background:linear-gradient(135deg,var(--yellow) 0%,#FFE29A 100%);
    transform:rotate(45deg);border-radius:6px;box-shadow:0 10px 18px -6px rgba(255,169,10,0.5);
    animation:hover-bob 2.6s ease-in-out infinite;}
  @keyframes hover-bob{0%,100%{transform:rotate(45deg) translateY(0);}50%{transform:rotate(45deg) translateY(-8px);}}
  h1{font-family:'Baloo 2',sans-serif;font-weight:800;font-size:20px;text-align:center;margin:2px 0 8px;}
  .board-holder{flex:1;display:flex;align-items:center;justify-content:center;position:relative;}
  canvas{background:#DFF7EA;border-radius:18px;box-shadow:0 14px 24px -10px rgba(30,70,53,0.25);
    max-width:100%;max-height:100%;}
  .hint{text-align:center;font-weight:700;color:var(--ink-soft);font-size:13px;margin-top:10px;}
  .overlay{position:fixed;inset:0;background:rgba(30,70,53,0.55);display:none;align-items:center;justify-content:center;z-index:10;}
  .overlay.show{display:flex;}
  .modal{background:var(--card-bg);border-radius:22px;padding:26px 24px;text-align:center;max-width:280px;
    box-shadow:0 20px 40px -10px rgba(0,0,0,0.35);}
  .modal h2{font-family:'Baloo 2',sans-serif;margin:0 0 8px;font-size:22px;color:var(--green-dark);}
  .modal p{font-weight:700;color:var(--ink-soft);margin:0 0 16px;}
  .btn-main{background:linear-gradient(135deg,var(--green),#7BE3A6);border:none;color:#fff;font-family:'Baloo 2',sans-serif;
    font-weight:700;font-size:16px;padding:12px 26px;border-radius:16px;box-shadow:0 8px 0 var(--green-dark);}
  .btn-main:active{transform:translateY(4px);box-shadow:0 4px 0 var(--green-dark);}
</style>
</head>
<body>
<div class="wrap">
  <div class="plumbob"></div>
  <h1>🐤 Flappy Bird</h1>
  <div class="board-holder"><canvas id="board" width="300" height="420"></canvas></div>
  <p class="hint">Тапни по экрану, чтобы взлететь</p>
</div>
<div class="overlay" id="overlay">
  <div class="modal">
    <h2>Игра окончена 🪶</h2>
    <p id="finalScore">Счёт: 0</p>
    <button class="btn-main" id="restart">Сыграть ещё</button>
  </div>
</div>
<script>
if(window.Telegram && window.Telegram.WebApp){window.Telegram.WebApp.ready();window.Telegram.WebApp.expand();}

const canvas=document.getElementById('board');
const ctx=canvas.getContext('2d');
const W=canvas.width, H=canvas.height;
let bird, pipes, score, alive, frame, gravity=0.45, jump=-7.5, pipeGap=130, pipeW=54, speed=2.4;

function reset(){
  bird={x:70,y:H/2,v:0,r:14};
  pipes=[];
  score=0; alive=true; frame=0;
  document.getElementById('overlay').classList.remove('show');
  spawnPipe();
  requestAnimationFrame(loop);
}
function spawnPipe(){
  const top=40+Math.random()*(H-pipeGap-160);
  pipes.push({x:W+20, top, passed:false});
}
function loop(){
  if(!alive) return;
  frame++;
  bird.v+=gravity; bird.y+=bird.v;
  if(frame%95===0) spawnPipe();
  pipes.forEach(p=>p.x-=speed);
  pipes = pipes.filter(p=>p.x>-pipeW);
  pipes.forEach(p=>{
    if(!p.passed && p.x+pipeW<bird.x){ p.passed=true; score++; }
    if(bird.x+bird.r>p.x && bird.x-bird.r<p.x+pipeW){
      if(bird.y-bird.r<p.top || bird.y+bird.r>p.top+pipeGap) gameOver();
    }
  });
  if(bird.y+bird.r>H || bird.y-bird.r<0) gameOver();
  draw();
  if(alive) requestAnimationFrame(loop);
}
function draw(){
  ctx.clearRect(0,0,W,H);
  ctx.fillStyle='#DFF7EA'; ctx.fillRect(0,0,W,H);
  ctx.fillStyle='#35C57A';
  pipes.forEach(p=>{
    ctx.fillRect(p.x,0,pipeW,p.top);
    ctx.fillRect(p.x,p.top+pipeGap,pipeW,H-(p.top+pipeGap));
  });
  ctx.fillStyle='#FFC94D';
  ctx.beginPath(); ctx.arc(bird.x,bird.y,bird.r,0,Math.PI*2); ctx.fill();
  ctx.fillStyle='#1E4635'; ctx.font='bold 26px sans-serif'; ctx.textAlign='center';
  ctx.fillText(score, W/2, 44);
}
function gameOver(){
  alive=false;
  document.getElementById('finalScore').textContent='Счёт: '+score;
  document.getElementById('overlay').classList.add('show');
}
function flap(){ if(alive){ bird.v=jump; } }
canvas.addEventListener('touchstart',e=>{e.preventDefault();flap();},{passive:false});
canvas.addEventListener('mousedown',flap);
document.addEventListener('keydown',e=>{ if(e.code==='Space') flap(); });
document.getElementById('restart').onclick=reset;
reset();
</script>
</body>
</html>
